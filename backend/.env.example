# ============================================================
# AEROSTRAT Backend Environment Variables
# 複製此檔案為 .env 並填入實際值
# ============================================================

# --- Server ---
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/aerostrat

# --- OpenSky Network (5 帳號輪換，至少填寫第一組) ---
OPENSKY_USER=your_opensky_username
OPENSKY_PASS=your_opensky_password

OPENSKY_USER2=
OPENSKY_PASS2=

OPENSKY_USER3=
OPENSKY_PASS3=

OPENSKY_USER4=
OPENSKY_PASS4=

OPENSKY_USER5=
OPENSKY_PASS5=

# --- External APIs (Optional) ---
AERODATABOX_API_KEY=
TDX_CLIENT_ID=
TDX_CLIENT_SECRET=
AIRLABS_API_KEY=
